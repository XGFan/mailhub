# ---------------------------------------------------------------------------
# MailHub portal (portal/server) environment.
# Copy to portal/server/.env for local dev. NEVER commit a filled-in .env.
# ---------------------------------------------------------------------------

# Postgres connection string (use a dedicated least-privilege role scoped to
# the `mailhub` schema — see plan §3 / §5.4).
DATABASE_URL=postgres://mailhub:mailhub@localhost:5432/mailhub

# R2 bucket exposed over the S3 API. For local dev this points at MinIO.
# The S3 token must be scoped to Get/List/Delete/Put on this one bucket only.
R2_ENDPOINT=http://localhost:9000
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mailhub-raw

# HTTP port the portal API listens on (Vite dev server proxies /api here).
PORT=8787

# Ingestor idle poll ceiling in ms — the top of the adaptive backoff ladder.
# The healthy loop re-checks fast after activity (5s), then relaxes 10s → 30s →
# this ceiling as the inbox stays empty. Default 60s.
POLL_INTERVAL_MS=60000

# Where parsed attachment bytes are written (a PVC in production).
ATTACHMENT_DIR=./data/attachments

# Reject any raw message larger than this (bytes). Default ~26 MiB.
MAX_MAIL_BYTES=27262976

# Auto-purge: delete mails + attachment files older than this many days.
RETENTION_DAYS=7

# Optional API keys for the /api/* gate (comma-separated). Leave unset/empty to
# keep the portal open (the default, no-auth behavior). When set, every /api/*
# request must present a valid key via `X-API-Key: <key>` or
# `Authorization: Bearer <key>`; /healthz, /readyz and the SPA stay open.
# Generate a key with: openssl rand -hex 32
# API_KEYS=

# Optional shared secret for the Cloudflare Worker "new mail" nudge
# (`POST /api/signal`), which triggers an immediate ingest so new mail lands in
# ~1s instead of waiting for the poll. Leave unset to hide that endpoint (404)
# and rely on polling only. Independent of API_KEYS. Generate: openssl rand -hex 32
# SIGNAL_KEY=
